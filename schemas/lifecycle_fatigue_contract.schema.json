{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Stage6 Lifecycle Fatigue Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "lifecycle_state",
    "time_scale",
    "decay_profile",
    "fatigue_score",
    "fatigue_bucket"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "stage6.lifecycle_fatigue.v1"
    },
    "lifecycle_state": {
      "type": "string",
      "enum": [
        "Detected",
        "Verified",
        "Active",
        "Continuation",
        "Exhaustion",
        "Dead",
        "Archived"
      ]
    },
    "time_scale": {
      "type": "string",
      "enum": ["intraday", "overnight", "multiweek", "none"]
    },
    "decay_profile": {
      "type": "string",
      "enum": ["fast", "medium", "slow", "exhausted", "none"]
    },
    "fatigue_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "fatigue_bucket": {
      "type": "string",
      "enum": ["none", "low", "medium", "high", "critical"]
    }
  }
}
