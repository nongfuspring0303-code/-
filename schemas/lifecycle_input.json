{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LifecycleManager Input",
  "description": "LifecycleManager 输入契约：事件对象到生命周期状态判定（兼容 C1 内部状态机）。",
  "type": "object",
  "required": [
    "event_id",
    "category",
    "severity",
    "source_rank",
    "detected_at"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "pattern": "^ME-[A-G]-\\d{8}-\\d{3}\\.V\\d+\\.\\d+$",
      "description": "事件唯一ID"
    },
    "category": {
      "type": "string",
      "enum": ["A", "B", "C", "D", "E", "F", "G"]
    },
    "severity": {
      "type": "string",
      "enum": ["E0", "E1", "E2", "E3", "E4"]
    },
    "source_rank": {
      "type": "string",
      "enum": ["A", "B", "B-", "C"]
    },
    "headline": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string"
    },
    "detected_at": {
      "type": "string",
      "format": "date-time"
    },
    "last_updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "previous_lifecycle_state": {
      "type": "string",
      "enum": ["Detected", "Verified", "Active", "Continuation", "Exhaustion", "Dead", "Archived"]
    },
    "previous_internal_state": {
      "type": "string",
      "enum": ["Detected", "Verified", "Hypothesis", "Validated", "Approved", "Executed", "Monitored", "Closed", "Reviewed"]
    },
    "previous_catalyst_state": {
      "type": "string",
      "enum": ["first_impulse", "continuation", "exhaustion", "dead"]
    },
    "is_official_confirmed": {
      "type": "boolean",
      "default": false
    },
    "market_validated": {
      "type": "boolean",
      "default": false
    },
    "has_material_update": {
      "type": "boolean",
      "default": false
    },
    "contradicted_by_new_fact": {
      "type": "boolean",
      "default": false
    },
    "ai_hypothesis_ready": {
      "type": "boolean",
      "default": false
    },
    "validation_passed": {
      "type": "boolean",
      "default": false
    },
    "risk_approved": {
      "type": "boolean",
      "default": false
    },
    "execution_confirmed": {
      "type": "boolean",
      "default": false
    },
    "monitoring_stable": {
      "type": "boolean",
      "default": false
    },
    "close_conditions_met": {
      "type": "boolean",
      "default": false
    },
    "review_completed": {
      "type": "boolean",
      "default": false
    },
    "retry_count": {
      "type": "integer",
      "minimum": 0,
      "default": 0
    },
    "max_retries": {
      "type": "integer",
      "minimum": 1,
      "default": 3
    },
    "elapsed_hours": {
      "type": "number",
      "minimum": 0
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "event_id": "ME-C-20260330-001.V1.0",
      "category": "C",
      "severity": "E3",
      "source_rank": "B",
      "headline": "美国宣布新一轮关税措施",
      "detected_at": "2026-03-30T13:30:00Z",
      "is_official_confirmed": false,
      "market_validated": false,
      "elapsed_hours": 1
    }
  ]
}
