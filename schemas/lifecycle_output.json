{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LifecycleManager Output",
  "description": "LifecycleManager 输出契约：内部统一状态 + 兼容生命周期状态。",
  "type": "object",
  "required": [
    "event_id",
    "internal_state",
    "lifecycle_state",
    "catalyst_state",
    "trade_eligibility",
    "holding_horizon",
    "transition_reason",
    "needs_manual_review"
  ],
  "properties": {
    "event_id": {
      "type": "string"
    },
    "internal_state": {
      "type": "string",
      "enum": ["Detected", "Verified", "Hypothesis", "Validated", "Approved", "Executed", "Monitored", "Closed", "Reviewed"]
    },
    "lifecycle_state": {
      "type": "string",
      "enum": ["Detected", "Verified", "Active", "Continuation", "Exhaustion", "Dead", "Archived"]
    },
    "legacy_lifecycle_state": {
      "type": "string",
      "enum": ["Detected", "Verified", "Active", "Continuation", "Exhaustion", "Dead", "Archived"]
    },
    "catalyst_state": {
      "type": "string",
      "enum": ["first_impulse", "continuation", "exhaustion", "dead"]
    },
    "trade_eligibility": {
      "type": "string",
      "enum": ["tradable", "watch", "blocked", "archive_only"]
    },
    "holding_horizon": {
      "type": "string",
      "enum": ["intraday", "overnight", "multiweek", "none"]
    },
    "transition_reason": {
      "type": "string"
    },
    "next_review_at": {
      "type": "string",
      "format": "date-time"
    },
    "needs_manual_review": {
      "type": "boolean"
    },
    "state_version": {
      "type": "string"
    },
    "reasoning": {
      "type": "string"
    },
    "state_mapping": {
      "type": "object",
      "required": ["internal_schema", "legacy_schema", "compatible"],
      "properties": {
        "internal_schema": { "type": "string" },
        "legacy_schema": { "type": "string" },
        "compatible": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "event_id": "ME-C-20260330-001.V1.0",
      "internal_state": "Validated",
      "lifecycle_state": "Active",
      "legacy_lifecycle_state": "Active",
      "catalyst_state": "first_impulse",
      "trade_eligibility": "tradable",
      "holding_horizon": "overnight",
      "transition_reason": "通过验证条件",
      "needs_manual_review": false,
      "state_version": "lifecycle_v1.1"
    }
  ]
}
