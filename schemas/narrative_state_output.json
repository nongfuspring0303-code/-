{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Narrative State Output",
  "type": "object",
  "required": ["trace_id", "event_id", "narrative_state", "transition_valid", "reasoning"],
  "properties": {
    "trace_id": { "type": "string" },
    "event_id": { "type": "string" },
    "previous_state": { "type": ["string", "null"] },
    "narrative_state": { "type": "string", "enum": ["initial", "continuation", "decay", "invalid"] },
    "transition_valid": { "type": "boolean" },
    "reasoning": { "type": "string" }
  },
  "additionalProperties": false
}

