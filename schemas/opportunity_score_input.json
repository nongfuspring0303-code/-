{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OpportunityScorer Input",
  "description": "B层机会评分输入：基于sector_update与候选股票生成机会池。",
  "type": "object",
  "required": ["trace_id", "schema_version", "sectors"],
  "properties": {
    "trace_id": {"type": "string"},
    "schema_version": {"type": "string"},
    "sectors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "direction", "impact_score", "confidence"],
        "properties": {
          "name": {"type": "string"},
          "direction": {"type": "string", "enum": ["LONG", "SHORT", "WATCH", "benefit", "hurt"]},
          "impact_score": {"type": "number", "minimum": 0, "maximum": 1},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1}
        },
        "additionalProperties": true
      }
    },
    "stock_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["symbol"],
        "properties": {
          "symbol": {"type": "string"},
          "sector": {"type": "string"},
          "direction": {"type": "string"},
          "event_beta": {"type": "number"}
        },
        "additionalProperties": true
      }
    },
    "timestamp": {"type": "string"}
  },
  "additionalProperties": true
}
