{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OpportunityScorer Output",
  "description": "B层机会池输出，包含完整机会卡字段。",
  "type": "object",
  "required": ["type", "trace_id", "schema_version", "opportunities", "timestamp"],
  "properties": {
    "type": {"type": "string", "const": "opportunity_update"},
    "trace_id": {"type": "string"},
    "schema_version": {"type": "string"},
    "opportunities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "symbol",
          "name",
          "sector",
          "signal",
          "entry_zone",
          "risk_flags",
          "final_action",
          "reasoning",
          "confidence",
          "timestamp"
        ],
        "properties": {
          "symbol": {"type": "string"},
          "name": {"type": "string"},
          "sector": {"type": "string"},
          "signal": {"type": "string", "enum": ["LONG", "SHORT", "WATCH"]},
          "entry_zone": {
            "type": "object",
            "required": ["support", "resistance"],
            "properties": {
              "support": {"type": "number"},
              "resistance": {"type": "number"}
            },
            "additionalProperties": false
          },
          "risk_flags": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["type", "level", "description"],
              "properties": {
                "type": {"type": "string"},
                "level": {"type": "string", "enum": ["low", "medium", "high"]},
                "description": {"type": "string"}
              },
              "additionalProperties": false
            }
          },
          "final_action": {"type": "string", "enum": ["EXECUTE", "WATCH", "BLOCK", "PENDING_CONFIRM"]},
          "reasoning": {"type": "string"},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "timestamp": {"type": "string"}
        },
        "additionalProperties": true
      }
    },
    "timestamp": {"type": "string"},
    "stats": {
      "type": "object",
      "properties": {
        "opportunity_count": {"type": "integer", "minimum": 0},
        "premium_pool_only": {"type": "boolean"}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
