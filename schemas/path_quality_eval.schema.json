{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Stage6 Path Quality Evaluation (Analysis Only)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "path_accuracy",
    "validation_accuracy",
    "direction_relative_accuracy",
    "direction_absolute_accuracy",
    "dominant_driver_accuracy",
    "expectation_gap_accuracy",
    "execution_decision_quality",
    "composite_score",
    "grade"
  ],
  "properties": {
    "path_accuracy": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "validation_accuracy": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "direction_relative_accuracy": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "direction_absolute_accuracy": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "dominant_driver_accuracy": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "expectation_gap_accuracy": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "execution_decision_quality": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "composite_score": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "grade": {
      "type": "string",
      "enum": ["Excellent", "Good", "Acceptable", "Poor", "Failed"]
    }
  }
}
