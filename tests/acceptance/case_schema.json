{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GoldenAcceptanceCase",
  "type": "object",
  "additionalProperties": false,
  "required": ["case_id", "category", "description", "input", "expect"],
  "properties": {
    "case_id": {"type": "string", "minLength": 3},
    "category": {
      "type": "string",
      "enum": ["macro", "policy", "earnings", "geopolitics", "low_trust"]
    },
    "risk_level": {"type": "string", "enum": ["A", "B", "C"]},
    "description": {"type": "string", "minLength": 5},
    "input": {
      "type": "object",
      "additionalProperties": true,
      "required": ["headline", "raw_text", "source_type", "source_url", "timestamp"],
      "properties": {
        "headline": {"type": "string", "minLength": 3},
        "raw_text": {"type": "string", "minLength": 3},
        "source_type": {"type": "string", "minLength": 1},
        "source_url": {"type": "string", "minLength": 8},
        "timestamp": {"type": "string", "minLength": 1}
      }
    },
    "scenario": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "path_blueprints": {
          "type": "array",
          "items": {"type": "object"}
        },
        "transmission_paths": {
          "type": "array",
          "items": {"type": "object"}
        },
        "sectors": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "direction", "impact_score", "confidence"],
            "properties": {
              "name": {"type": "string"},
              "direction": {"type": "string", "enum": ["LONG", "SHORT", "WATCH"]},
              "impact_score": {"type": "number"},
              "confidence": {"type": "number"}
            }
          }
        },
        "stock_candidates": {
          "type": "array",
          "items": {"type": "object"}
        },
        "asset_validation": {
          "type": "object",
          "properties": {
            "score": {"type": "number"}
          }
        },
        "risk_blocked": {"type": "boolean"}
      }
    },
    "expect": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "required_fields",
        "allowed_signals",
        "forbidden_signals",
        "expected_path_types_any_of",
        "max_final_action"
      ],
      "properties": {
        "required_fields": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string"}
        },
        "allowed_signals": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "enum": ["LONG", "SHORT", "WATCH"]}
        },
        "forbidden_signals": {
          "type": "array",
          "items": {"type": "string", "enum": ["LONG", "SHORT", "WATCH"]}
        },
        "expected_path_types_any_of": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": ["fundamental", "asset_pricing", "narrative"]
          }
        },
        "max_final_action": {
          "type": "string",
          "enum": ["BLOCK", "PENDING_CONFIRM", "WATCH", "EXECUTE"]
        },
        "allow_empty_opportunities": {"type": "boolean"},
        "must_have_gate_reason_code": {"type": "boolean"}
      }
    }
  }
}
